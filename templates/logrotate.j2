{{ log_dir }}/{{ cluster_name }}/*.log {
{% if rootless == false %}
    su picodata picodata
{% endif %}
    daily
    size 1M
    missingok
    rotate 10
    compress
    create 0640 {{ user }} {{ group }}
    sharedscripts
    postrotate
{% if init_system == 'supervisord' %}
        /usr/bin/supervisorctl -c {{ supervisord_dir }}/{{ cluster_name }}.conf signal HUP all
{% else %}
{% if autonames == false %}
        /usr/bin/systemctl kill {% if rootless == true %}--user{% endif %} --all -s HUP {{ cluster_name }}@*
{% else %}
        /usr/bin/systemctl kill {% if rootless == true %}--user{% endif %} --all -s HUP {{ cluster_name }}-???
{% endif %}
{% endif %}
    endscript
}
